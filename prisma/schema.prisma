datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─── GOOGLE NEWS COMPLIANT AUTHOR TABLE ───
model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String
  password    String
  title       String?   
  bio         String?   
  avatarUrl   String?   
  sameAsLinks String[]  
  role        String    @default("AUTHOR") 
  articles    Article[]
  createdAt   DateTime  @default(now())
}

// ─── GOOGLE NEWS COMPLIANT ARTICLE TABLE ───
model Article {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  excerpt      String?  
  content      String   
  imageUrl     String?  
  category     String   @default("General") 
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())   
  updatedAt    DateTime @updatedAt        
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
}
